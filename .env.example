# Copy to .env and fill in values before running the scraper or dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/shelf_intelligence

# ScraperAPI key for Walmart scraping (required for live Walmart data)
# Sign up at https://www.scraperapi.com — 5,000 free trial credits
# When set, WalmartScraper uses ScraperAPI instead of plain Playwright
SCRAPERAPI_KEY=

# Optional: residential proxy for Playwright-based scrapers (Amazon)
PROXY_URL=

# Optional: enables Cinderhaven lost-revenue callout in OOS Tracker tab
# Set to average daily revenue in dollars (e.g., 500 for $500/day)
CINDERHAVEN_DAILY_REVENUE=0
